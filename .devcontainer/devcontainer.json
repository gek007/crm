{
  "name": "Personal CRM (Pi)",
  "build": { "dockerfile": "Dockerfile" },
  "workspaceFolder": "/workspaces/crm",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/crm,type=bind",
  "remoteUser": "node",
  "forwardPorts": [5173],
  "postCreateCommand": "pi install npm:pi-web-access && if [ -f package.json ]; then npm install; fi",
  "customizations": {
    "vscode": {
      "extensions": ["dbaeumer.vscode-eslint", "esbenp.prettier-vscode"]
    }
  }
}
